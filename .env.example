# Leave empty in dev to use Vite proxy (see vite.config.ts → :3000).
# In production, set to your API origin, e.g. https://api.example.com
VITE_API_URL=

# On bloom-at-work-api, add this app origin to CORS_ORIGINS when not using the proxy
# (e.g. http://localhost:8081).
#
# Console login is validated on the API with:
#   BACKOFFICE_USERNAME, BACKOFFICE_PASSWORD
# Optional: BACKOFFICE_TOKEN_SECRET (min 16 chars) for HS256; if omitted, key is derived from user+password.
